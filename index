function parseNumbers(text){return text.split(new RegExp('[\\n,;\\t ]+')).map(Number).filter(Number.isFinite)}
function normalYieldForTol(tols){
  const sigma=Math.sqrt(tols.reduce((s,t)=>s+(t/3)**2,0));
  return sigma>0?erf(state.target/(sigma*Math.sqrt(2)))*100:100;
}
function cylinderAxialFluxGauss(gapMm){
  const d=+document.getElementById('magDiameter').value;
  const thickness=+document.getElementById('magThickness').value;
  const br=+document.getElementById('magBr').value;
  const factor=+document.getElementById('fieldFactor').value;
  const R=Math.max(0.001,d/2);
  const z=Math.max(0.001,gapMm);
  const bzTesla=(br/2)*(((z+thickness)/Math.sqrt(R*R+(z+thickness)*(z+thickness)))-(z/Math.sqrt(R*R+z*z)));
  return Math.max(0,bzTesla*10000*factor);
}

function linkedScenario(tols){
  const nominalGap=+document.getElementById('refGap').value;
  const cpg=+document.getElementById('countPerG').value;
  const minFlux=+document.getElementById('minFlux').value;
  const ee=+document.getElementById('eeNoise').value||0;
  const factor=+document.getElementById('fwFactor').value||3;
  const sigmaGap=Math.sqrt(tols.reduce((s,t)=>s+(t/3)**2,0));
  const mechanicalYield=normalYieldForTol(tols);
  const nominalFlux=cylinderAxialFluxGauss(nominalGap);
  const upperGapFlux=cylinderAxialFluxGauss(nominalGap+3*sigmaGap);
  const magneticYield=upperGapFlux>=minFlux?99.73:Math.max(0,Math.min(99.73,(upperGapFlux/minFlux)*99.73));
  const derivative=Math.abs(cylinderAxialFluxGauss(nominalGap+0.01)-cylinderAxialFluxGauss(nominalGap-0.01))/0.02;
  const countSigma=derivative*sigmaGap*cpg;
  const raw=parseNumbers(document.getElementById('fwData').value);
  const baselineStd=std(raw,mean(raw));
  const systemCountSigma=Math.sqrt(baselineStd**2+countSigma**2+ee**2);
  const fwPass=Math.max(0,Math.min(100,erf(factor/Math.sqrt(2))*100));
  const systemYield=mechanicalYield/100*magneticYield/100*fwPass/100*100;
  const cpk=sigmaGap>0?state.target/(3*sigmaGap):99;
  return {mechanicalYield,magneticYield,fwPass,systemYield,countSigma,systemCountSigma,cpk,nominalFlux,upperGapFlux};
}

function runHW(){
  state.target=parseFloat(document.getElementById('targetSpec').value)||.05;
  const n=parseInt(document.getElementById('iters').value),mode=document.getElementById('distMode').value;
  state.rss=Math.sqrt(state.components.reduce((s,c)=>s+c.tol**2,0));
  const res=new Float32Array(n);let pass=0;
  for(let i=0;i<n;i++){let g=0;for(const c of state.components){g+=mode==='uniform'?(Math.random()*2-1)*c.tol:randn()*(c.tol/3)}res[i]=g;if(Math.abs(g)<=state.target)pass++}
  state.results=Array.from(res);state.mean=mean(state.results);state.std=std(state.results,state.mean);state.yield=pass/n*100;
  state.cp=(2*state.target)/(6*state.std);state.cpk=Math.min((state.target-state.mean)/(3*state.std),(state.mean+state.target)/(3*state.std));state.ppk=state.cpk;state.ppm=(1-state.yield/100)*1e6;
  document.getElementById('kpiYield').textContent=fmt(state.yield)+'%';document.getElementById('kpiCpk').textContent=fmt(state.cpk);document.getElementById('kpiSigma').textContent=fmt(state.cpk*3)+'σ';document.getElementById('kpiRSS').textContent=fmt(state.rss,3)+' mm';document.getElementById('kpiPPM').textContent=Math.round(state.ppm).toLocaleString();
  const r=document.getElementById('kpiRisk'),risk=state.yield>=99.7?'LOW':state.yield>=95?'MEDIUM':'HIGH';r.textContent=risk;r.className='text-xl font-bold '+(risk==='LOW'?'text-status-pass':risk==='MEDIUM'?'text-status-warn':'text-status-fail');
  updateHWCharts();
}
function updateHWCharts(){
  const bins=42,min=-state.target*2,max=state.target*2,step=(max-min)/bins,h=new Array(bins).fill(0),labels=[];
  for(let i=0;i<bins;i++)labels.push((min+(i+.5)*step).toFixed(3));
  state.results.forEach(v=>{const b=Math.floor((v-min)/step);if(b>=0&&b<bins)h[b]++});
  charts.hist.data.labels=labels;charts.hist.data.datasets[0].data=h;charts.hist.data.datasets[0].backgroundColor=labels.map(x=>Math.abs(+x)>state.target?'#ef4444':'#38bdf8');charts.hist.update();
  const ss=state.components.reduce((s,c)=>s+c.tol**2,0),p=state.components.map(c=>({n:c.name,v:ss?c.tol**2/ss*100:0})).sort((a,b)=>b.v-a.v);
  charts.tornado.data.labels=p.map(x=>x.n);charts.tornado.data.datasets[0].data=p.map(x=>x.v);charts.tornado.update();
}
function applyMagProfile(){
  const p=document.getElementById('magGrade').value;
  const presets={
    bmn50sh:{d:6.0,t:2.5,br:1.40,f:0.18},
    n42:{d:6.0,t:2.5,br:1.30,f:0.18},
    n52:{d:6.0,t:2.5,br:1.45,f:0.18}
  };
  if(!presets[p])return;
  document.getElementById('magDiameter').value=presets[p].d;
  document.getElementById('magThickness').value=presets[p].t;
  document.getElementById('magBr').value=presets[p].br;
  document.getElementById('fieldFactor').value=presets[p].f;
}
function runMag(){
  const nominalGap=+document.getElementById('refGap').value;
  const refCount=+document.getElementById('refCount').value;
  const cpg=+document.getElementById('countPerG').value;
  const minFlux=+document.getElementById('minFlux').value;
  const nominalFlux=cylinderAxialFluxGauss(nominalGap);

  state.flux=state.results.map(g=>cylinderAxialFluxGauss(Math.max(0.001,nominalGap+g)));
  state.counts=state.flux.map(f=>refCount+(f-nominalFlux)*cpg);
  state.fluxMean=mean(state.flux);
  state.fluxP05=quantile(state.flux,.05);
  state.countMean=mean(state.counts);
  state.fluxPass=state.flux.filter(f=>f>=minFlux).length/Math.max(1,state.flux.length)*100;
  state.magneticYield=state.fluxPass;

  document.getElementById('magGapKpi').textContent=fmt(nominalGap,3)+' mm';
  document.getElementById('magFluxKpi').textContent=fmt(state.fluxMean,1)+' G';
  document.getElementById('magP05Kpi').textContent=fmt(state.fluxP05,1)+' G';
  document.getElementById('magCountKpi').textContent=fmt(state.countMean,1);
  const p=document.getElementById('magPassKpi');
  p.textContent=fmt(state.fluxPass)+'%';
  p.className='text-xl font-mono '+(state.fluxPass>=99.7?'text-status-pass':'text-status-warn');

  const xs=[],ys=[];
  const start=Math.max(0.01,nominalGap-state.target*2);
  const end=nominalGap+state.target*2;
  for(let g=start;g<=end;g+=(end-start)/40){xs.push(g.toFixed(3));ys.push(cylinderAxialFluxGauss(g))}
  charts.fluxGap.data.labels=xs;
  charts.fluxGap.data.datasets[0].data=ys;
  charts.fluxGap.data.datasets[0].label='BMN-50SH/ST axial Bz (G)';
  charts.fluxGap.update();

  const stride=Math.max(1,Math.floor(state.flux.length/400));
  charts.countFlux.data.datasets[0].data=state.flux.filter((_,i)=>i%stride===0).map((f,i)=>({x:f,y:state.counts[i*stride]}));
  charts.countFlux.update();
}
function runFW(){
  const raw=parseNumbers(document.getElementById('fwData').value);
  const m=mean(raw),bs=std(raw,m),ee=+document.getElementById('eeNoise').value||0,f=+document.getElementById('fwFactor').value;
  const countStd=std(state.counts,state.countMean);
  const sys=Math.sqrt(bs**2+countStd**2+ee**2);
  state.fw={mean:m,baseStd:bs,sysStd:sys,lsl:m-f*sys,usl:m+f*sys,fr:(1-erf(f/Math.sqrt(2)))*100};
  state.fwPass=100-state.fw.fr;
  document.getElementById('fwFactorLabel').textContent=f.toFixed(1)+'σ';
  document.getElementById('fwMean').textContent=fmt(m,1);
  document.getElementById('fwBaseStd').textContent=fmt(bs,2);
  document.getElementById('fwSysStd').textContent=fmt(sys,2);
  document.getElementById('fwRange').textContent=fmt(state.fw.lsl,1)+' ~ '+fmt(state.fw.usl,1);
  document.getElementById('fwFR').textContent=fmt(state.fw.fr,3)+'%';
  const minFlux=+document.getElementById('minFlux').value;
  state.systemPassMask=state.results.map((g,i)=>{
    const mechanical=Math.abs(g)<=state.target;
    const magnetic=state.flux[i]>=minFlux;
    const centeredCount=m+(state.counts[i]-state.countMean);
    const fw=centeredCount>=state.fw.lsl&&centeredCount<=state.fw.usl;
    return mechanical&&magnetic&&fw;
  });
  state.systemYield=state.systemPassMask.filter(Boolean).length/Math.max(1,state.systemPassMask.length)*100;
  document.getElementById('kpiSystemYield').textContent=fmt(state.systemYield)+'%';
  const labels=[],data=[];for(let x=1;x<=6;x+=.25){labels.push(x.toFixed(2));data.push((1-erf(x/Math.sqrt(2)))*100)}
  charts.fw.data.labels=labels;charts.fw.data.datasets[0].data=data;charts.fw.update();
}
function estimateYield(tols){return linkedScenario(tols).systemYield}
function renderDOE(){
  const ss=state.components.reduce((s,c)=>s+c.tol**2,0);document.getElementById('doeMatrix').innerHTML=state.components.map(c=>`<tr class="border-t border-brand-border"><td class="p-2">${c.name}</td><td>${c.tol.toFixed(3)}</td><td>${(c.tol*.75).toFixed(3)}</td><td>${c.cost.toFixed(1)}×</td><td>${fmt(c.tol**2/ss*100,1)}%</td></tr>`).join('');
}
function runDOE(){
  const n=state.components.length,candidates=[],total=1<<n;
  for(let mask=0;mask<total;mask++){
    const tols=[],changes=[];let cost=0;
    state.components.forEach((c,i)=>{const tight=!!(mask&(1<<i)),t=tight?c.tol*.75:c.tol;tols.push(t);if(tight){cost+=c.cost;changes.push(i)}});
    const linked=linkedScenario(tols);candidates.push({...linked,cost,changes,tols});
  }
  const feasible=candidates.filter(x=>x.systemYield>=99.7).sort((a,b)=>a.cost-b.cost||b.systemYield-a.systemYield);
  const best=feasible[0]||[...candidates].sort((a,b)=>b.systemYield-a.systemYield||a.cost-b.cost)[0];
  state.doe=best;
  document.getElementById('doeResult').innerHTML=`<div>System-yield target: <b>99.70%</b></div><div>Mechanical: <b>${fmt(best.mechanicalYield)}%</b></div><div>Magnetic: <b>${fmt(best.magneticYield)}%</b></div><div>FW pass: <b>${fmt(best.fwPass)}%</b></div><div>Linked system yield: <b class="${best.systemYield>=99.7?'text-status-pass':'text-status-warn'}">${fmt(best.systemYield)}%</b></div><div>Relative cost: <b>+${fmt(best.cost,1)}</b></div><div class="pt-2 border-t border-brand-border">${best.changes.length?best.changes.map(i=>`${state.components[i].name}: ${state.components[i].tol.toFixed(3)} → ${best.tols[i].toFixed(3)} mm`).join('<br>'):'No tightening selected.'}</div>`;
  const btn=document.getElementById('applyDoeBtn');btn.disabled=false;btn.className='px-3 py-1 rounded bg-brand-accent text-brand-dark text-[11px] font-bold';
  charts.pareto.data.datasets[0].data=candidates.map(x=>({x:x.cost,y:x.systemYield}));
  charts.pareto.data.datasets[1].data=[{x:best.cost,y:best.systemYield}];charts.pareto.update();
  runCapability();runAI();generateReport();
}
function applyDOE(){
  if(!state.doe)return;
  state.components.forEach((c,i)=>c.tol=state.doe.tols[i]);
  state.doe=null;renderComponents();
  const btn=document.getElementById('applyDoeBtn');btn.disabled=true;btn.className='px-3 py-1 rounded bg-slate-700 text-slate-400 text-[11px] font-bold cursor-not-allowed';
  document.getElementById('doeResult').innerHTML='<div class="text-status-pass font-bold">DOE tolerances applied to the master model.</div><div>All tabs and the report were recalculated.</div>';
  runAll();
}
function runCapability(){
  document.getElementById('capCp').textContent=fmt(state.cp);
  document.getElementById('capCpk').textContent=fmt(state.cpk);
  document.getElementById('capPpk').textContent=fmt(state.ppk);
  document.getElementById('capSigma').textContent=fmt(state.cpk*3)+'σ';
  document.getElementById('capPpm').textContent=Math.round((1-state.systemYield/100)*1e6).toLocaleString();
  document.getElementById('capMean').textContent=fmt(state.mean,4);
  document.getElementById('capStd').textContent=fmt(state.std,4);
  const s=state.systemYield>=99.7&&state.cpk>=1.33?'CAPABLE':state.systemYield>=95?'MARGINAL':'NOT CAPABLE';
  const el=document.getElementById('capStatus');el.textContent=s;el.className='text-xl font-bold '+(s==='CAPABLE'?'text-status-pass':s==='MARGINAL'?'text-status-warn':'text-status-fail');
  charts.capGauge.data.datasets[0].data=[Math.max(0,state.cpk)];
  charts.capGauge.data.datasets[0].backgroundColor=[state.cpk>=1.33?'#22c55e':state.cpk>=1?'#f59e0b':'#ef4444'];charts.capGauge.update();
  const doeY=state.doe?state.doe.systemYield/100:state.systemYield/100;
  charts.capTrend.data.datasets[0].data=[state.yield/100,state.magneticYield/100,state.fwPass/100,state.systemYield/100,doeY];
  charts.capTrend.update();
}
function runAI(){
  const ss=state.components.reduce((s,c)=>s+c.tol**2,0),rank=[...state.components].map(c=>({...c,impact:c.tol**2/ss*100})).sort((a,b)=>b.impact-a.impact),top=rank[0];
  const rec=[];
  if(state.systemYield<99.7)rec.push({level:'HIGH',title:'End-to-end system yield below target',body:`Linked system yield is ${fmt(state.systemYield)}% (mechanical ${fmt(state.yield)}%, magnetic ${fmt(state.magneticYield)}%, FW ${fmt(state.fwPass)}%). Prioritize ${top.name}, which contributes ${fmt(top.impact,1)}% of stack variance.`});
  else rec.push({level:'LOW',title:'End-to-end system meets target',body:`Linked system yield is ${fmt(state.systemYield)}%. Maintain process controls and verify with pilot-run data.`});
  if(state.fluxPass<99.7)rec.push({level:'HIGH',title:'Magnetic margin is insufficient',body:`Flux pass rate is ${fmt(state.fluxPass)}%. For DRFQ23-08 BMN-50SH/ST, first verify actual Bz with a gauss meter; then evaluate smaller nominal gap, installation alignment, shielding loss, or tighter gap-related tolerances.`});
  else rec.push({level:'LOW',title:'Magnetic margin is acceptable',body:`P05 flux is ${fmt(state.fluxP05,1)} G and flux pass rate is ${fmt(state.fluxPass)}%.`});
  if(state.cpk<1.33)rec.push({level:'MEDIUM',title:'Cpk below typical production target',body:`Current Cpk is ${fmt(state.cpk)}. Run DOE and confirm actual process mean shift before release.`});
  if(state.fw.fr>.3)rec.push({level:'MEDIUM',title:'FW false reject risk',body:`Current theoretical false reject rate is ${fmt(state.fw.fr,3)}%. Increase threshold factor only after checking false-accept risk.`});
  document.getElementById('aiRecommendations').innerHTML=rec.map(r=>`<div class="border border-brand-border rounded p-3"><div class="font-bold ${r.level==='HIGH'?'text-status-fail':r.level==='MEDIUM'?'text-status-warn':'text-status-pass'}">[${r.level}] ${r.title}</div><div class="text-xs text-slate-400 mt-1">${r.body}</div></div>`).join('');
  const overall=rec.some(r=>r.level==='HIGH')?'HIGH':rec.some(r=>r.level==='MEDIUM')?'MEDIUM':'LOW';document.getElementById('aiSummary').innerHTML=`<div>Overall risk: <b class="${overall==='HIGH'?'text-status-fail':overall==='MEDIUM'?'text-status-warn':'text-status-pass'}">${overall}</b></div><div>Main contributor: <b>${top.name}</b></div><div>Contribution: <b>${fmt(top.impact,1)}%</b></div><div>Recommended owner: <b>${overall==='HIGH'?'ME + FW + Supplier':'ME / Quality'}</b></div><div>Confidence: <b>${state.results.length>=50000?'High':'Medium'}</b></div>`;
}
function generateReport(){
  document.getElementById('reportDate').textContent=new Date().toLocaleDateString('zh-TW');document.getElementById('repYield').textContent=fmt(state.systemYield)+'%';document.getElementById('repCpk').textContent=fmt(state.cpk);document.getElementById('repFlux').textContent=fmt(state.fluxPass)+'%';document.getElementById('repFW').textContent=fmt(state.fw.lsl,1)+' ~ '+fmt(state.fw.usl,1);
  const ss=state.components.reduce((s,c)=>s+c.tol**2,0),worst=[...state.components].sort((a,b)=>b.tol-a.tol)[0];
  document.getElementById('repSummary').innerHTML=`<li>Linked system yield is <b>${fmt(state.systemYield)}%</b> (mechanical ${fmt(state.yield)}%, magnetic ${fmt(state.magneticYield)}%, FW ${fmt(state.fwPass)}%); Cpk is <b>${fmt(state.cpk)}</b>.</li><li>Magnetic model estimates P05 flux of <b>${fmt(state.fluxP05,1)} G</b> and flux pass rate of <b>${fmt(state.fluxPass)}%</b>.</li><li>Main tolerance contributor is <b>${worst?.name||'--'}</b>.</li><li>FW recommended pass range is <b>${fmt(state.fw.lsl,1)} ~ ${fmt(state.fw.usl,1)}</b>.</li><li>${state.doe?`DOE selected ${state.doe.changes.length} tolerance change(s), estimated yield ${fmt(state.doe.systemYield)}%.`:'Run DOE before final release decision.'}</li>`;
  document.getElementById('repMagnet').innerHTML=`<b>DRFQ23-08 BMN-50SH/ST</b> · NdFeB · Φ${(+document.getElementById('magDiameter').value).toFixed(1)} × ${(+document.getElementById('magThickness').value).toFixed(1)} mm · Br input ${(+document.getElementById('magBr').value).toFixed(2)} T · Nominal gap ${(+document.getElementById('refGap').value).toFixed(3)} mm · Installation factor ${(+document.getElementById('fieldFactor').value).toFixed(2)}`;
  document.getElementById('repTable').innerHTML=state.components.map((c,i)=>`<tr class="border-b"><td class="p-2">${c.name}</td><td>±${c.tol.toFixed(3)} mm</td><td>${fmt(c.tol**2/ss*100,1)}%</td><td>${state.doe&&state.doe.changes.includes(i)?'Tighten to ±'+state.doe.tols[i].toFixed(3):'Maintain'}</td></tr>`).join('');
}

function updateSystemRisk(){
  const r=document.getElementById('kpiRisk');
  const risk=state.systemYield>=99.7?'LOW':state.systemYield>=95?'MEDIUM':'HIGH';
  r.textContent=risk;r.className='text-xl font-bold '+(risk==='LOW'?'text-status-pass':risk==='MEDIUM'?'text-status-warn':'text-status-fail');
}

function runAll(){runHW();runMag();runFW();updateSystemRisk();renderDOE();runCapability();runAI();generateReport()}
window.onload=()=>{
  const mock=Array.from({length:40},()=>50+randn()*2.5);document.getElementById('fwData').value=mock.map(v=>v.toFixed(2)).join('\n');
  renderComponents();initCharts();applyMagProfile();runAll();
};
</script>
