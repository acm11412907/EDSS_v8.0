  charts.fw=new Chart(document.getElementById('fwChart'),{type:'line',data:{labels:[],datasets:[{label:'False Reject %',data:[],borderColor:'#ef4444',backgroundColor:'rgba(239,68,68,.15)',fill:true,tension:.25}]},options:{responsive:true,maintainAspectRatio:false,plugins:{title:{display:true,text:'Threshold Trade-off'}},scales:{x:{title:{display:true,text:'Threshold factor (σ)'},grid:{color:'#334155'}},y:{beginAtZero:true,grid:{color:'#334155'}}}}});
  charts.pareto=new Chart(document.getElementById('paretoChart'),{type:'scatter',data:{datasets:[{label:'Candidate solutions',data:[],backgroundColor:'#38bdf8'},{label:'Selected',data:[],backgroundColor:'#22c55e',pointRadius:8}]},options:{responsive:true,maintainAspectRatio:false,plugins:{title:{display:true,text:'Yield vs Relative Cost'}},scales:{x:{title:{display:true,text:'Relative cost'},grid:{color:'#334155'}},y:{title:{display:true,text:'Yield %'},grid:{color:'#334155'}}}}});
  charts.capGauge=new Chart(document.getElementById('capGauge'),{type:'bar',data:{labels:['Cpk'],datasets:[{data:[0],backgroundColor:['#38bdf8']}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},title:{display:true,text:'Process Capability Gauge'}},scales:{x:{min:0,max:2,title:{display:true,text:'Cpk'},grid:{color:'#334155'}},y:{grid:{display:false}}}}});
