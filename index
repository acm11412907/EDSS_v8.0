<!DOCTYPE html>
<html lang="zh-Hant" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EDSS v8.0 - Coco test</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            brand: { dark:'#0b1220', panel:'#172033', panel2:'#1d2940', accent:'#38bdf8', border:'#334155' },
            status: { pass:'#22c55e', warn:'#f59e0b', fail:'#ef4444' }
          },
          fontFamily: { sans:['Segoe UI','Microsoft JhengHei','sans-serif'], mono:['Consolas','monospace'] }
        }
      }
    };
  </script>
  <style>
    body{background:#0b1220;color:#cbd5e1}
    .tab-content{display:none}.tab-content.active{display:flex}
    .tab-btn.active{color:#38bdf8;border-bottom:2px solid #38bdf8}
    .glass{background:linear-gradient(145deg,rgba(29,41,64,.95),rgba(23,32,51,.9))}
    input[type=range]{accent-color:#38bdf8}
    ::-webkit-scrollbar{width:7px;height:7px}
    ::-webkit-scrollbar-thumb{background:#334155;border-radius:4px}
    @media print{
      header,.no-print{display:none!important}
      body{background:#fff!important;color:#000!important}
      .tab-content{display:none!important}
      #tab-report{display:flex!important}
      .print-panel{border:1px solid #bbb;break-inside:avoid}
    }
  </style>
</head>
<body class="min-h-screen font-sans text-sm">
<header class="sticky top-0 z-20 bg-brand-panel border-b border-brand-border px-4 py-3 no-print">
  <div class="flex flex-col xl:flex-row gap-3 justify-between xl:items-center">
    <div>
      <div class="text-white font-bold text-lg">DS-070KN-01 <span class="text-brand-accent text-sm font-normal ml-2">Coco test</span></div>
      <div class="text-[10px] text-slate-500">Tolerance · Magnetic Flux · Firmware · Capability </div>
    </div>
    <div class="flex flex-col lg:flex-row gap-3 lg:items-center overflow-x-auto">
      <nav class="flex gap-4 text-xs font-bold text-slate-400 whitespace-nowrap">
        <button class="tab-btn active pb-1" onclick="switchTab('tab-hw',this)">1. HW</button>
        <button class="tab-btn pb-1" onclick="switchTab('tab-mag',this)">2. Magnetic</button>
        <button class="tab-btn pb-1" onclick="switchTab('tab-fw',this)">3. FW</button>
        <button class="tab-btn pb-1" onclick="switchTab('tab-doe',this)">4. DOE</button>
        <button class="tab-btn pb-1" onclick="switchTab('tab-cap',this)">5. Capability</button>
        <button class="tab-btn pb-1" onclick="switchTab('tab-ai',this)">6. Decision</button>
        <button class="tab-btn pb-1" onclick="switchTab('tab-report',this)">7. Report</button>
      </nav>
      <button onclick="window.print()" class="px-4 py-1.5 rounded bg-brand-accent text-brand-dark font-bold text-xs">Export PDF</button>
    </div>
  </div>
</header>

<main>
<section id="tab-hw" class="tab-content active min-h-screen flex-col lg:flex-row">
  <aside class="w-full lg:w-[360px] bg-brand-panel border-r border-brand-border p-4">
    <div class="flex justify-between items-center border-b border-brand-border pb-3 mb-4">
      <span class="text-xs text-brand-accent font-bold">Functional SPEC (±mm)</span>
      <input id="targetSpec" value="0.05" step="0.005" type="number" class="w-24 bg-transparent border-b border-brand-border text-white font-mono text-right text-lg outline-none" oninput="runAll()">
    </div>
    <div class="grid grid-cols-2 gap-2 mb-4">
      <label class="text-[10px] text-slate-500">Iterations
        <select id="iters" class="w-full mt-1 bg-brand-dark border border-brand-border text-white p-1.5" onchange="runAll()">
          <option value="10000">10,000</option><option value="50000" selected>50,000</option><option value="100000">100,000</option>
        </select>
      </label>
      <label class="text-[10px] text-slate-500">Distribution
        <select id="distMode" class="w-full mt-1 bg-brand-dark border border-brand-border text-white p-1.5" onchange="runAll()">
          <option value="normal" selected>Normal</option><option value="uniform">Uniform</option>
        </select>
      </label>
    </div>
    <div class="flex justify-between items-center mb-3">
      <span class="text-xs font-bold text-slate-400">Component Stack-up</span>
      <button onclick="addComponent()" class="text-brand-accent text-xs">+ Add Part</button>
    </div>
    <div id="componentList" class="space-y-3"></div>
  </aside>
  <div class="flex-grow p-4 bg-brand-dark"><div class="mb-3 px-3 py-2 rounded border border-brand-accent/40 bg-sky-950/30 text-[11px] text-sky-200">Live data flow: Tolerance → Gap → Flux → Sensor Count → FW Decision → Capability → DOE → Decision Engine → Report</div>
    <div class="grid grid-cols-2 xl:grid-cols-7 gap-2">
      <div class="glass border border-brand-border rounded p-3"><div class="text-[10px] text-slate-500">YIELD</div><div id="kpiYield" class="text-xl text-white font-mono"></div></div>
      <div class="glass border border-brand-border rounded p-3"><div class="text-[10px] text-slate-500">Cpk</div><div id="kpiCpk" class="text-xl text-white font-mono"></div></div>
      <div class="glass border border-brand-border rounded p-3"><div class="text-[10px] text-slate-500">SIGMA</div><div id="kpiSigma" class="text-xl text-white font-mono"></div></div>
      <div class="glass border border-brand-border rounded p-3"><div class="text-[10px] text-slate-500">RSS</div><div id="kpiRSS" class="text-xl text-white font-mono"></div></div>
      <div class="glass border border-brand-border rounded p-3"><div class="text-[10px] text-slate-500">PPM</div><div id="kpiPPM" class="text-xl text-white font-mono"></div></div>
      <div class="glass border border-brand-border rounded p-3"><div class="text-[10px] text-slate-500">SYSTEM YIELD</div><div id="kpiSystemYield" class="text-xl text-brand-accent font-mono"></div></div><div class="glass border border-brand-border rounded p-3"><div class="text-[10px] text-slate-500">RISK</div><div id="kpiRisk" class="text-xl font-bold"></div></div>
    </div>
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 mt-4">
      <div class="glass border border-brand-border rounded p-3 h-[380px]"><canvas id="histChart"></canvas></div>
      <div class="glass border border-brand-border rounded p-3 h-[380px]"><canvas id="tornadoChart"></canvas></div>
    </div>
  </div>
</section>

<section id="tab-mag" class="tab-content min-h-screen flex-col lg:flex-row">
  <aside class="w-full lg:w-[380px] bg-brand-panel border-r border-brand-border p-4 space-y-4">
    <h2 class="text-brand-accent font-bold">Module 1 · BMN-50SH/ST Magnetic Model</h2>
    <div class="rounded border border-brand-accent/40 bg-sky-950/30 p-3 text-[11px]">
      <div class="text-white font-bold">Magnet</div>
      <div class="text-sky-200 mt-1">BMN-50SH/ST · NdFeB · Φ6 × 2.5 mm</div>
    </div>
    <p class="text-[11px] text-slate-500">Uses an axial cylindrical-magnet field approximation. Br and installation offset must be calibrated with RD gauss-meter data before production release.</p>

    <label class="block text-xs">Magnet profile
      <select id="magGrade" class="w-full mt-1 p-2 bg-brand-dark border border-brand-border text-white" onchange="applyMagProfile();runAll()">
        <option value="custom">Custom</option>
        <option value="bmn50sh" selected>BMN-50SH/ST Φ6×2.5</option>
        <option value="n42">Reference N42 Φ6×2.5</option>
        <option value="n52">Reference N52 Φ6×2.5</option>
      </select>
    </label>

    <div class="grid grid-cols-2 gap-2">
      <label class="block text-xs">Diameter (mm)<input id="magDiameter" type="number" value="6.0" step="0.1" class="w-full mt-1 p-2 bg-brand-dark border border-brand-border text-white" oninput="runAll()"></label>
      <label class="block text-xs">Thickness (mm)<input id="magThickness" type="number" value="2.5" step="0.1" class="w-full mt-1 p-2 bg-brand-dark border border-brand-border text-white" oninput="runAll()"></label>
    </div>

    <label class="block text-xs">Remanence Br (T, calibration input)<input id="magBr" type="number" value="1.40" step="0.01" class="w-full mt-1 p-2 bg-brand-dark border border-brand-border text-white" oninput="runAll()"></label>
    <label class="block text-xs">Nominal magnet-to-sensor gap (mm)<input id="refGap" type="number" value="0.30" step="0.01" class="w-full mt-1 p-2 bg-brand-dark border border-brand-border text-white" oninput="runAll()"></label>
    <label class="block text-xs">Installation / shielding factor<input id="fieldFactor" type="number" value="0.18" step="0.01" min="0.01" max="1" class="w-full mt-1 p-2 bg-brand-dark border border-brand-border text-white" oninput="runAll()"></label>
    <label class="block text-xs">Count at nominal condition<input id="refCount" type="number" value="500" step="1" class="w-full mt-1 p-2 bg-brand-dark border border-brand-border text-white" oninput="runAll()"></label>
    <label class="block text-xs">Sensor transfer gain (count/G)<input id="countPerG" type="number" value="0.65" step="0.01" class="w-full mt-1 p-2 bg-brand-dark border border-brand-border text-white" oninput="runAll()"></label>
    <label class="block text-xs">Minimum acceptable flux density (G)<input id="minFlux" type="number" value="470" step="1" class="w-full mt-1 p-2 bg-brand-dark border border-brand-border text-white" oninput="runAll()"></label>
  </aside>
  <div class="flex-grow p-4">
    <div class="grid grid-cols-2 xl:grid-cols-5 gap-2">
      <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">NOMINAL GAP</div><div id="magGapKpi" class="text-xl font-mono text-white"></div></div>
      <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">MEAN Bz</div><div id="magFluxKpi" class="text-xl font-mono text-white"></div></div>
      <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">P05 Bz</div><div id="magP05Kpi" class="text-xl font-mono text-white"></div></div>
      <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">MEAN COUNT</div><div id="magCountKpi" class="text-xl font-mono text-white"></div></div>
      <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">MAGNETIC PASS</div><div id="magPassKpi" class="text-xl font-mono"></div></div>
    </div>
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 mt-4">
      <div class="glass border border-brand-border rounded p-3 h-[380px]"><canvas id="fluxGapChart"></canvas></div>
      <div class="glass border border-brand-border rounded p-3 h-[380px]"><canvas id="countFluxChart"></canvas></div>
    </div>
  </div>
</section>

<section id="tab-fw" class="tab-content min-h-screen flex-col lg:flex-row">
  <aside class="w-full lg:w-[360px] bg-brand-panel border-r border-brand-border p-4">
    <h2 class="text-brand-accent font-bold mb-2">FW Threshold</h2>
    <textarea id="fwData" class="w-full h-40 p-2 bg-brand-dark border border-brand-border text-white font-mono text-xs" oninput="runAll()"></textarea>
    <label class="block text-xs mt-4">EE noise (1σ count)<input id="eeNoise" value="2" step="0.1" type="number" class="w-full mt-1 p-2 bg-brand-dark border border-brand-border text-white" oninput="runAll()"></label>
    <label class="block text-xs mt-4">Threshold factor <span id="fwFactorLabel" class="float-right text-brand-accent"></span>
      <input id="fwFactor" min="1" max="6" step="0.1" value="3" type="range" class="w-full mt-2" oninput="runAll()">
    </label>
  </aside>
  <div class="flex-grow p-4">
    <div class="grid grid-cols-2 xl:grid-cols-5 gap-2">
      <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">BASELINE MEAN</div><div id="fwMean" class="text-xl font-mono text-white"></div></div>
      <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">BASELINE σ</div><div id="fwBaseStd" class="text-xl font-mono text-white"></div></div>
      <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">SYSTEM σ</div><div id="fwSysStd" class="text-xl font-mono text-white"></div></div>
      <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">PASS RANGE</div><div id="fwRange" class="text-lg font-mono text-status-pass"></div></div>
      <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">FALSE REJECT</div><div id="fwFR" class="text-xl font-mono text-status-warn"></div></div>
    </div>
    <div class="glass border border-brand-border rounded p-3 h-[460px] mt-4"><canvas id="fwChart"></canvas></div>
  </div>
</section>

<section id="tab-doe" class="tab-content min-h-screen flex-col p-4">
  <div class="flex justify-between items-center">
    <div><h2 class="text-white font-bold text-lg">Module 3 · Cost-aware DOE Optimizer</h2><p class="text-xs text-slate-500">Searches discrete tolerance options for the lowest estimated cost meeting the yield target.</p></div>
    <button onclick="runDOE()" class="px-5 py-2 rounded bg-brand-accent text-brand-dark font-bold">Run Optimization</button>
  </div>
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-4 mt-4">
    <div class="glass border border-brand-border rounded p-4 xl:col-span-2">
      <div class="text-xs font-bold text-brand-accent mb-3">Tolerance / Cost Matrix</div>
      <div class="overflow-x-auto"><table class="w-full text-xs"><thead><tr class="text-left text-slate-500"><th class="p-2">Part</th><th>Current</th><th>Tight option</th><th>Cost weight</th><th>Contribution</th></tr></thead><tbody id="doeMatrix"></tbody></table></div>
    </div>
    <div class="glass border border-brand-border rounded p-4"><div class="flex justify-between items-center mb-3"><div class="text-xs font-bold text-status-warn">Optimization Result</div><button id="applyDoeBtn" onclick="applyDOE()" disabled class="px-3 py-1 rounded bg-slate-700 text-slate-400 text-[11px] font-bold cursor-not-allowed">Apply DOE</button></div><div id="doeResult" class="space-y-2 text-xs">Press Run Optimization.</div></div>
  </div>
  <div class="glass border border-brand-border rounded p-3 h-[400px] mt-4"><canvas id="paretoChart"></canvas></div>
</section>

<section id="tab-cap" class="tab-content min-h-screen flex-col p-4">
  <h2 class="text-white font-bold text-lg">Module 4 · Capability Dashboard</h2>
  <div class="grid grid-cols-2 xl:grid-cols-8 gap-2 mt-4">
    <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">Cp</div><div id="capCp" class="text-xl font-mono text-white"></div></div>
    <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">Cpk</div><div id="capCpk" class="text-xl font-mono text-white"></div></div>
    <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">Ppk</div><div id="capPpk" class="text-xl font-mono text-white"></div></div>
    <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">Sigma</div><div id="capSigma" class="text-xl font-mono text-white"></div></div>
    <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">PPM</div><div id="capPpm" class="text-xl font-mono text-white"></div></div>
    <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">Mean</div><div id="capMean" class="text-xl font-mono text-white"></div></div>
    <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">Std</div><div id="capStd" class="text-xl font-mono text-white"></div></div>
    <div class="glass border border-brand-border p-3 rounded"><div class="text-[10px] text-slate-500">Status</div><div id="capStatus" class="text-xl font-bold"></div></div>
  </div>
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 mt-4">
    <div class="glass border border-brand-border p-3 rounded h-[400px]"><canvas id="capGauge"></canvas></div>
    <div class="glass border border-brand-border p-3 rounded h-[400px]"><canvas id="capTrend"></canvas></div>
  </div>
</section>

<section id="tab-ai" class="tab-content min-h-screen flex-col p-4">
  <h2 class="text-white font-bold text-lg">Module 5 · Engineering Decision Engine</h2>
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-4 mt-4">
    <div class="glass border border-brand-border rounded p-4 xl:col-span-2"><div class="text-xs font-bold text-brand-accent mb-3">Engineering Recommendations</div><div id="aiRecommendations" class="space-y-3"></div></div>
    <div class="glass border border-brand-border rounded p-4"><div class="text-xs font-bold text-status-warn mb-3">Decision Summary</div><div id="aiSummary" class="space-y-2 text-xs"></div></div>
  </div>
  <div class="glass border border-brand-border rounded p-4 mt-4">
    <div class="text-xs font-bold mb-3">Risk Matrix</div>
    <div class="grid grid-cols-4 gap-1 text-center text-xs">
      <div></div><div class="p-2 text-slate-500">Low probability</div><div class="p-2 text-slate-500">Medium</div><div class="p-2 text-slate-500">High</div>
      <div class="p-2 text-slate-500">High impact</div><div class="p-3 bg-yellow-900/40">Monitor</div><div class="p-3 bg-red-900/40">Mitigate</div><div id="riskHigh" class="p-3 bg-red-700/60">Critical</div>
      <div class="p-2 text-slate-500">Medium impact</div><div class="p-3 bg-green-900/40">Accept</div><div id="riskMedium" class="p-3 bg-yellow-900/50">Control</div><div class="p-3 bg-red-900/40">Mitigate</div>
      <div class="p-2 text-slate-500">Low impact</div><div id="riskLow" class="p-3 bg-green-800/50">Accept</div><div class="p-3 bg-green-900/40">Monitor</div><div class="p-3 bg-yellow-900/40">Control</div>
    </div>
  </div>
</section>

<section id="tab-report" class="tab-content min-h-screen flex-col bg-white text-black p-8">
  <div class="max-w-5xl mx-auto w-full space-y-6">
    <div class="border-b-2 border-black pb-4"><h1 class="text-3xl font-bold">EDSS v8.0 Engineering Report</h1><div class="flex justify-between text-sm text-gray-600 mt-2"><span>Project: DS-070KN-01</span><span id="reportDate"></span></div></div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="print-panel bg-gray-50 p-4"><div class="text-xs text-gray-500">Yield</div><div id="repYield" class="text-2xl font-bold"></div></div>
      <div class="print-panel bg-gray-50 p-4"><div class="text-xs text-gray-500">Cpk</div><div id="repCpk" class="text-2xl font-bold"></div></div>
      <div class="print-panel bg-gray-50 p-4"><div class="text-xs text-gray-500">Flux Pass</div><div id="repFlux" class="text-2xl font-bold"></div></div>
      <div class="print-panel bg-gray-50 p-4"><div class="text-xs text-gray-500">FW Range</div><div id="repFW" class="text-lg font-bold"></div></div>
    </div>
    <div class="print-panel p-4"><h3 class="font-bold text-lg border-b pb-2 mb-3">Executive Summary</h3><ul id="repSummary" class="list-disc pl-5 space-y-2"></ul></div>
    <div class="print-panel p-4"><h3 class="font-bold text-lg border-b pb-2 mb-3">Magnet Configuration</h3><div id="repMagnet" class="text-sm"></div></div><div class="print-panel p-4"><h3 class="font-bold text-lg border-b pb-2 mb-3">Tolerance Configuration</h3><table class="w-full text-sm"><thead class="bg-gray-100"><tr><th class="p-2 text-left">Component</th><th class="text-left">Tolerance</th><th class="text-left">Variance Contribution</th><th class="text-left">DOE Suggestion</th></tr></thead><tbody id="repTable"></tbody></table></div>
  </div>
</section>
</main>

<script>
const state={
  components:[
    {name:'PCB Thickness',tol:0.08,cost:1.4},
    {name:'Housing Holder',tol:0.04,cost:1.8},
    {name:'Plastic Knob',tol:0.03,cost:1.3},
    {name:'Adhesive Layer',tol:0.03,cost:1.2},
    {name:'Magnet Thickness',tol:0.02,cost:1.5}
  ],
  results:[], target:0.05, mean:0, std:0, rss:0, yield:0, cp:0, cpk:0, ppk:0, ppm:0,
  flux:[], counts:[], fluxPass:0, fluxMean:0, fluxP05:0, countMean:0,
  fw:{mean:0,baseStd:0,sysStd:0,lsl:0,usl:0,fr:0},
  doe:null, systemYield:0, fwPass:0, magneticYield:0, systemPassMask:[]
};
const charts={};
function randn(){let u=0,v=0;while(!u)u=Math.random();while(!v)v=Math.random();return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v)}
function mean(a){return a.reduce((s,v)=>s+v,0)/Math.max(1,a.length)}
function std(a,m=mean(a)){return Math.sqrt(a.reduce((s,v)=>s+(v-m)**2,0)/Math.max(1,a.length))}
function quantile(a,q){const b=[...a].sort((x,y)=>x-y),p=(b.length-1)*q,i=Math.floor(p),f=p-i;return b[i]+(b[i+1]??b[i])*f}
function erf(x){const s=x>=0?1:-1;x=Math.abs(x);const a1=.254829592,a2=-.284496736,a3=1.421413741,a4=-1.453152027,a5=1.061405429,p=.3275911,t=1/(1+p*x);return s*(1-(((((a5*t+a4)*t)+a3)*t+a2)*t+a1)*t*Math.exp(-x*x))}
function fmt(v,d=2){return Number.isFinite(v)?v.toFixed(d):'--'}
function switchTab(id,btn){document.querySelectorAll('.tab-content').forEach(x=>x.classList.remove('active'));document.querySelectorAll('.tab-btn').forEach(x=>x.classList.remove('active'));document.getElementById(id).classList.add('active');btn.classList.add('active');if(id==='tab-report')generateReport()}
function addComponent(){state.components.push({name:'New Part',tol:.03,cost:1.3});renderComponents();runAll()}
function removeComponent(i){state.components.splice(i,1);renderComponents();runAll()}
function renderComponents(){
  const el=document.getElementById('componentList');el.innerHTML='';
  state.components.forEach((c,i)=>{
    el.innerHTML+=`<div class="bg-brand-dark border border-brand-border rounded p-3">
      <div class="flex gap-2 mb-2">
        <input value="${c.name}" class="flex-grow bg-transparent text-white font-bold text-xs outline-none" onchange="state.components[${i}].name=this.value;runAll()">
        <button class="text-status-fail" onclick="removeComponent(${i})">×</button>
      </div>
      <div class="grid grid-cols-2 gap-2">
        <label class="text-[10px] text-slate-500">Tolerance ±mm<input type="number" value="${c.tol}" step="0.005" class="w-full mt-1 p-1.5 bg-brand-panel border border-brand-border text-white" oninput="state.components[${i}].tol=parseFloat(this.value)||.001;runAll()"></label>
        <label class="text-[10px] text-slate-500">Tightening cost<input type="number" value="${c.cost}" step="0.1" class="w-full mt-1 p-1.5 bg-brand-panel border border-brand-border text-white" oninput="state.components[${i}].cost=parseFloat(this.value)||1;runAll()"></label>
      </div>
    </div>`;
  });
}
