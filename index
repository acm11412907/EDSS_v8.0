  charts.hist=new Chart(document.getElementById('histChart'),{type:'bar',data:{labels:[],datasets:[{data:[],backgroundColor:[]}]},options:{responsive:true,maintainAspectRatio:false,animation:false,plugins:{legend:{display:false},title:{display:true,text:'Gap Distribution'}},scales:{x:{grid:{color:'#334155'}},y:{grid:{color:'#334155'}}}}});
  charts.tornado=new Chart(document.getElementById('tornadoChart'),{type:'bar',data:{labels:[],datasets:[{data:[],backgroundColor:'#38bdf8'}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,animation:false,plugins:{legend:{display:false},title:{display:true,text:'Variance Contribution %'}},scales:{x:{grid:{color:'#334155'}},y:{grid:{display:false}}}}});
  charts.fluxGap=new Chart(document.getElementById('fluxGapChart'),{type:'line',data:{labels:[],datasets:[{label:'Flux (G)',data:[],borderColor:'#38bdf8',tension:.25}]},options:{responsive:true,maintainAspectRatio:false,plugins:{title:{display:true,text:'Flux vs Gap'}},scales:{x:{title:{display:true,text:'Gap (mm)'},grid:{color:'#334155'}},y:{grid:{color:'#334155'}}}}});
